<mujoco model="taluy_6dof">
    <!-- Keep MuJoCo gravity/fluid off; restoring and drag are external. -->
    <option timestep="0.01" gravity="0 0 0" density="0" viscosity="0"/>

    <asset>
        <mesh name="taluy_body_mesh" file="TALUY.stl" scale="1 1 1"/>
    </asset>

    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300" mark="none"/>
        <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    </asset>

    <worldbody>
        <light name="light" pos="0 0 20"/>
        <geom name="ground" type="plane" pos="0 0 -5" size="50 50 .1" material="grid"/>
    </worldbody>

    <worldbody>
        <include file="taluy_body_mjcf.xml"/>
    </worldbody>

    <include file="taluy_equipment_mjcf.xml"/>
</mujoco>
